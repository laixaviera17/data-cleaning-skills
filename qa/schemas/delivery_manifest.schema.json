{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "delivery_manifest.schema.json",
  "title": "Cleaned Dataset Delivery Manifest",
  "type": "object",
  "required": ["dataset_name", "generated_at", "package_layout", "file_count", "files"],
  "properties": {
    "dataset_name": {"type": "string", "minLength": 1},
    "generated_at": {"type": "string", "format": "date-time"},
    "package_layout": {
      "type": "array",
      "items": {"type": "string"},
      "minItems": 1
    },
    "file_count": {"type": "integer", "minimum": 1},
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "role", "size_bytes", "sha256", "source_path"],
        "properties": {
          "path": {"type": "string", "minLength": 1},
          "role": {"type": "string", "enum": ["data", "reports", "logs", "metadata", "docs", "extras"]},
          "size_bytes": {"type": "integer", "minimum": 0},
          "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
          "source_path": {"type": "string"}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
