{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "catalog_metadata.schema.json",
  "title": "Dataset Catalog Metadata",
  "type": "object",
  "required": [
    "catalog_standard",
    "dataset_id",
    "dataset_name",
    "description",
    "version",
    "source",
    "license",
    "authorization_type",
    "tags",
    "generated_at",
    "format",
    "record_count",
    "field_count",
    "schema",
    "files",
    "artifacts",
    "lineage",
    "standard_field_mapping",
    "required_field_status"
  ],
  "properties": {
    "catalog_standard": {"type": "string", "const": "NDI-TR-2025-06"},
    "dataset_id": {"type": "string", "minLength": 1},
    "dataset_name": {"type": "string", "minLength": 1},
    "description": {"type": "string"},
    "version": {"type": "string", "minLength": 1},
    "source": {"type": "string"},
    "license": {"type": "string"},
    "authorization_type": {"type": "string"},
    "tags": {"type": "array", "items": {"type": "string"}},
    "generated_at": {"type": "string", "format": "date-time"},
    "format": {"type": "string", "minLength": 1},
    "record_count": {"type": "integer", "minimum": 0},
    "field_count": {"type": "integer", "minimum": 0},
    "schema": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "type", "missing_cells"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "type": {"type": "string"},
          "missing_cells": {"type": "integer", "minimum": 0}
        },
        "additionalProperties": false
      }
    },
    "files": {"type": "array", "minItems": 1},
    "artifacts": {"type": "array"},
    "lineage": {"type": "object"},
    "standard_field_mapping": {"type": "object"},
    "required_field_status": {
      "type": "object",
      "required": ["standard", "required_fields", "missing_fields", "valid"],
      "properties": {
        "standard": {"type": "string"},
        "required_fields": {"type": "array", "items": {"type": "string"}},
        "missing_fields": {"type": "array", "items": {"type": "string"}},
        "valid": {"type": "boolean"}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}
