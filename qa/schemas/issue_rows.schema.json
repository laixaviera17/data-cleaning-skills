{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "issue_rows.schema.json",
  "title": "Structured Issue Rows CSV",
  "type": "object",
  "required": ["columns"],
  "properties": {
    "columns": {
      "type": "array",
      "prefixItems": [
        {"const": "row"},
        {"const": "field"},
        {"const": "value"},
        {"const": "issue_type"},
        {"const": "reason"}
      ],
      "minItems": 5
    },
    "row_contract": {
      "type": "object",
      "properties": {
        "row": {"type": "integer", "minimum": 1},
        "field": {"type": "string"},
        "value": {"type": ["string", "number", "boolean", "null"]},
        "issue_type": {"type": "string"},
        "reason": {"type": "string"}
      }
    }
  },
  "additionalProperties": false
}
